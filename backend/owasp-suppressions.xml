<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppressions.

  Add an entry per false positive or CVE we have explicitly accepted. Each entry
  needs a justification comment that explains why suppression is safe.

  Run a scan:
    mvn -P security-scan verify

  Reports are written to target/dependency-check-report.html.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Example suppression — uncomment and edit when needed:

        <suppress>
            <notes><![CDATA[
                Reason: <why this CVE does not apply or is accepted>
                Date: <YYYY-MM-DD>
            ]]></notes>
            <packageUrl regex="true">^pkg:maven/com\.example/library@.*$</packageUrl>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>
    -->
</suppressions>
