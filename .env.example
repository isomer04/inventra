# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit secrets.

# MySQL service
MYSQL_DATABASE=inventra
# Development Compose may use this convenience account. Production Compose ignores
# it and creates explicit runtime, migration, and backup users instead.
MYSQL_USER=inventra
MYSQL_PASSWORD=inventra
MYSQL_ROOT_PASSWORD=root
BACKUP_PASSWORD=replace-with-a-distinct-backup-password
# Host port for MySQL (change if 3306 is already in use locally)
MYSQL_HOST_PORT=3306

# App service (development Compose mirrors the convenience MySQL account above)
DB_URL=jdbc:mysql://mysql:3306/inventra?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
# Production Compose ignores DB_USERNAME/DB_PASSWORD and always wires the
# initializer-created inventra_app identity to APP_PASSWORD.
DB_USERNAME=inventra
DB_PASSWORD=inventra

# Development Flyway can use the same account as the app. Production Compose
# ignores FLYWAY_USER and always wires inventra_flyway to FLYWAY_PASSWORD.
FLYWAY_USER=inventra
FLYWAY_PASSWORD=inventra
APP_PASSWORD=inventra

# JWT — generate a strong secret with: openssl rand -base64 64
JWT_SECRET=
# Token lifetimes (optional — defaults shown)
JWT_ACCESS_EXPIRY_MS=900000      # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days

# CORS — comma-separated list of allowed frontend origins
# Development default: http://localhost:4200
# Production example:  https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Trust X-Forwarded-For header for rate-limiter client IP resolution.
# Set to "true" ONLY when the backend is reachable exclusively through a
# trusted reverse proxy that controls the header (e.g. nginx in our prod
# compose setup). With direct internet exposure, "true" allows clients to
# spoof their IP and bypass rate limits.
# Default (unset/false): always uses the direct connection address (safe).
TRUST_FORWARDED_FOR=false

# ── TLS / HTTPS ──────────────────────────────────────────────────────────────
# TLS is mandatory in docker-compose.prod.yml. The frontend container exits when
# cert.pem or key.pem is absent; it never falls back to plaintext in production.
#
# Step 1 — Obtain a certificate (choose one):
#   Production:  certbot certonly --standalone -d yourdomain.com
#   Staging:     ./scripts/gen-self-signed-cert.sh
#
# Step 2 — Set TLS_CERT_DIR to the directory containing cert.pem + key.pem.
#   Default: /etc/ssl/inventra (standard location on the host)
#   The directory is mounted read-only into the frontend container.
TLS_CERT_DIR=/etc/ssl/inventra

# Host directory containing the runtime maintenance marker used by restore.sh.
# Create it before the first production start: mkdir -p .maintenance
MAINTENANCE_DIR=./.maintenance

# Step 3 — Update CORS_ALLOWED_ORIGINS to use https://
#   (already set above — change http:// to https:// for your domain)

# Step 4 — Restart: docker compose -f docker-compose.prod.yml restart frontend

# Step 5 — After confirming HTTPS works, submit to https://hstspreload.org

# DOMAIN_NAME is informational (used in runbook / docs — not consumed by app)
DOMAIN_NAME=yourdomain.com
