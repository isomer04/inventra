*.iml
*.ipr
*.iws
.idea_modules/
*.swp
*.swo
*~

# VS Code — project root workspace settings only
.vscode/
*.code-workspace

# Eclipse
.classpath
.project
.settings/
.factorypath

# ─── OS metadata ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
.Trashes
